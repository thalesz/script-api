# NOTE: This file is intentionally versioned for this technical challenge.
# Do not put real secrets here. Keep real credentials only in local .env.
# =========================
# Local development (.env)
# =========================
# Used by: script/src/* and api/app/* when running outside Docker.
# Required for DB access in local runs: PG_HOST, PG_PORT, PG_DATABASE, PG_USER, PG_PASSWORD
PG_HOST=localhost
# Use 5433 when your DB is the docker-compose postgres service (5433:5432).
# Use 5432 when your DB is a native local PostgreSQL instance.
PG_PORT=5432
PG_DATABASE=sncr
PG_USER=postgres
PG_PASSWORD=postgres

# Scraper tuning
HEADLESS=false
CONCURRENCY=3
RESET_CHECKPOINT=true
STATE_RETRY_ROUNDS=2
MAX_ATTEMPTS=100
DOWNLOAD_TIMEOUT=15000
CAPTCHA_TIMEOUT=7
SHORT_SLEEP=0.8
SELECT_TIMEOUT=5
BASE_URL=https://data-engineer-challenge-production.up.railway.app/

# API metadata
APP_NAME=Desafio API
APP_VERSION=0.1.0

# =========================
# Docker Compose overrides
# =========================
# Used by: docker-compose.yml service environments.
DOCKER_HEADLESS=true
DOCKER_PG_HOST=postgres
DOCKER_PG_PORT=5432
DOCKER_PG_DATABASE=sncr
DOCKER_PG_USER=postgres
DOCKER_PG_PASSWORD=postgres
DOCKER_POSTGRES_DB=sncr
DOCKER_POSTGRES_USER=postgres
DOCKER_POSTGRES_PASSWORD=postgres
